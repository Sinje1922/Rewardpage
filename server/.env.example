# Database connection string (PostgreSQL/MySQL/etc)
DATABASE_URL="postgresql://user:password@localhost:5432/rewarddb?schema=public"

# JWT Secret for authentication
JWT_SECRET="generate-a-long-random-string-here"

# Port (optional, defaults to 4000)
# PORT=4000

# Allowed CORS origin (Production Frontend URL)
# CORS_ORIGIN="https://your-app.vercel.app"

# Google OAuth for Social Login & YouTube
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
YOUTUBE_REDIRECT_URI="https://api.yourdomain.com/api/oauth/youtube/callback"

# Discord OAuth
DISCORD_CLIENT_ID="your-discord-client-id"
DISCORD_CLIENT_SECRET="your-discord-client-secret"
DISCORD_REDIRECT_URI="https://api.yourdomain.com/api/oauth/discord/callback"
DISCORD_BOT_TOKEN="your-discord-bot-token"

# Frontend URL (for redirects after OAuth)
FRONTEND_URL="https://app.yourdomain.com"
