generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model analyticsevent {
  id        String   @id @default(cuid())
  name      String
  userId    String?
  meta      String   @default("{}") @db.Text
  createdAt DateTime @default(now())
}

model campaign {
  id                String    @id @default(cuid())
  title             String
  description       String    @default("")
  companyName       String    @default("")
  companyLogoUrl    String    @default("")
  status            String    @default("DRAFT")
  creatorId         String
  startsAt          DateTime?
  endsAt            DateTime?
  winnerCount       Int       @default(1)
  lotteryMode       String    @default("SIMPLE")
  autoApprove       Boolean   @default(true)
  totalRewardPoints Int       @default(0)
  createdAt         DateTime  @default(now())
  drawnAt           DateTime?
  creator           user?     @relation(fields: [creatorId], references: [id], map: "Campaign_creatorId_fkey")
  missions          mission[]
  winners           winner[]

  @@index([creatorId], map: "Campaign_creatorId_fkey")
}

model mission {
  id          String       @id @default(cuid())
  campaignId  String
  type        String
  title       String
  description String       @default("")
  sortOrder   Int          @default(0)
  config      String       @default("{}") @db.Text
  createdAt   DateTime     @default(now())
  campaign    campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade, map: "Mission_campaignId_fkey")
  submissions  submission[]

  @@index([campaignId], map: "Mission_campaignId_fkey")
}

model submission {
  id        String   @id @default(cuid())
  userId    String
  missionId String
  status    String   @default("PENDING")
  payload   String   @default("{}") @db.Text
  createdAt DateTime @default(now())
  mission   mission  @relation(fields: [missionId], references: [id], onDelete: Cascade, map: "Submission_missionId_fkey")
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Submission_userId_fkey")

  @@unique([userId, missionId], map: "Submission_userId_missionId_key")
  @@index([missionId], map: "Submission_missionId_fkey")
}

model user {
  id            String       @id @default(cuid())
  email         String       @unique(map: "User_email_key")
  passwordHash  String?
  role          String       @default("USER")
  blocked       Boolean      @default(false)
  pointBalance  Int          @default(0)
  country       String?
  locale        String?
  lastIp        String?
  birthYear     Int?
  walletAddress String?
  nickname      String?
  avatarUrl     String?
  createdAt     DateTime     @default(now())
  birthDate     DateTime?
  gender        String?
  region        String?
  telegramHandle String?
  discordId      String?
  discordHandle  String?
  youtubeHandle  String?
  instagramHandle String?
  updatedAt     DateTime     @default(now()) @updatedAt
  submissions   submission[]
  campaigns     campaign[]
  winners       winner[]
}

model winner {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  rank       Int
  points     Int      @default(0)
  createdAt  DateTime @default(now())
  campaign   campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade, map: "Winner_campaignId_fkey")
  user       user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Winner_userId_fkey")

  @@unique([campaignId, userId], map: "Winner_campaignId_userId_key")
  @@index([userId], map: "Winner_userId_fkey")
}
